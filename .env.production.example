NODE_ENV=production
PORT=4000
API_PUBLIC_URL=https://api.example.com
DATABASE_URL=postgresql://homenet:replace-me@postgres:5432/homenet?schema=public
REDIS_URL=redis://redis:6379
KAFKA_BROKERS=kafka:9092
JWT_ACCESS_SECRET=replace-with-64-plus-random-chars
JWT_REFRESH_SECRET=replace-with-64-plus-random-chars
MFA_SECRET_ENCRYPTION_KEY=replace-with-random-secret
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
STORAGE_ROOT=/var/lib/homenet/storage
CLAMD_HOST=clamav
CLAMD_PORT=3310
EXPO_ACCESS_TOKEN=
CORS_ORIGINS=https://app.example.com
LIVEKIT_URL=wss://livekit.example.com
LIVEKIT_API_KEY=replace-livekit-key
LIVEKIT_API_SECRET=replace-livekit-secret
